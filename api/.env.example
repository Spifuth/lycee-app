# Backend lycee-app — modèle de configuration.
# Copie ce fichier en `.env` et adapte si besoin. Les valeurs par défaut
# suffisent pour développer en local. NE METS JAMAIS de vrai secret ici :
# `.env` est ignoré par git, `.env.example` ne contient que des exemples.

APP_ENV=dev

# Base SQLite locale (un simple fichier dans le dossier api/)
DATABASE_URL=sqlite:///./app.db

# Secret de signature des sessions (JWT).
# En local, n'importe quelle valeur marche. En prod : `openssl rand -hex 32`.
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_TTL_DAYS=30

# URLs publiques / CORS (frontend en local = port 4321)
PUBLIC_BASE_URL=http://localhost:4321
CORS_ORIGINS=http://localhost:4321

# Avatars DiceBear (laisse tel quel ; les avatars ne s'afficheront pas en local
# sans un container DiceBear, ce n'est pas grave pour développer)
DICEBEAR_URL=http://localhost:3000
DICEBEAR_STYLE=pixel-art

# Module IA (proxy Ollama). Laisse OLLAMA_URL vide pour désactiver le module.
OLLAMA_URL=
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_S=30
OLLAMA_RATE_LIMIT_PER_MIN=3

# Compte admin : hash argon2 d'un mot de passe (généré via `python -m app.cli
# hash-admin-password`). Laisse vide si tu n'as pas besoin de l'admin en local.
ADMIN_PASSWORD_HASH=

# Secret partagé pour les appels du bot Discord (lycee-bot). Vide en local.
BOT_TOKEN=
FENRIRBOT_URL=http://localhost:8085

# Webhooks / invitation Discord (vides en local)
DISCORD_WEBHOOK_QUESTIONS=
DISCORD_WEBHOOK_STAFF=
DISCORD_INVITE_URL=

# Limites de débit (anti-spam)
RATE_LIMIT_SIGNUP_PER_HOUR=15
RATE_LIMIT_EVENTS_PER_MIN=60
