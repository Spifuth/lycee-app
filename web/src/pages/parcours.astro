    alternance: "N/A",
    apres: "Embauche possible si portfolio solide · CompTIA Sec+, OSCP, AWS, etc.",
    pourQui: "Tu es discipliné·e, tu finis tes projets perso, tu sais te vendre sans diplôme. Réaliste avec un peu plus d'effort sur la chasse de stage / 1er emploi.",
    color: "#ec4899",
  },
];

const COLS = [
  { key: "duree",       label: "Durée" },
  { key: "selectivite", label: "Sélectivité" },
  { key: "type",        label: "Type" },
  { key: "cout",        label: "Coût" },
  { key: "alternance",  label: "Alternance" },
  { key: "apres",       label: "Après ?" },
];
---

<Layout title="Parcours d'études">
  <h1 class="mb-2 font-display text-3xl font-bold">Après le bac — les parcours</h1>
  <p class="mb-8 text-ink-400">
    7 voies pour faire de l'info / cyber. Aucune n'est meilleure que l'autre — elles répondent à des questions différentes.
    Choisis celle qui colle à <em>ton</em> rythme et <em>ta</em> manière d'apprendre.
  </p>

  <div class="space-y-4">
    {VOIES.map((v) => (
      <article
        class="rounded-lg border border-ink-800 bg-ink-900/40 p-5"
        style={`border-left: 4px solid ${v.color}`}
      >
        <header class="flex items-baseline gap-3 mb-3 flex-wrap">
          <span class="text-2xl">{v.emoji}</span>
          <h2 class="font-display text-xl font-semibold text-ink-100">{v.nom}</h2>
        </header>

        <dl class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 text-sm">
          {COLS.map((c) => (
            <div>
              <dt class="font-mono text-[10px] uppercase tracking-wide text-ink-500">{c.label}</dt>
              <dd class="text-ink-200">{(v as any)[c.key]}</dd>
            </div>
          ))}
        </dl>

        <p class="mt-4 rounded bg-ink-950/60 p-3 text-sm italic text-ink-300">
          <span class="font-mono text-xs text-ink-500">→ pour qui : </span>{v.pourQui}
        </p>
      </article>
    ))}
  </div>

  <div class="mt-12 grid gap-4 md:grid-cols-2">
    <div class="rounded-lg border border-accent-500/30 bg-accent-500/5 p-5">
      <p class="font-mono text-xs text-accent-400">CONSEIL #1 — VOIE PAS LINÉAIRE OK</p>
      <p class="mt-2 text-sm text-ink-200">
        Tu peux faire un BTS, hésiter, rejoindre une école d'ingé par passerelle, partir en alternance, revenir en master.
        Personne dans ce métier ne suit la trajectoire « parfaite » du début à la fin.
      </p>
    </div>
    <div class="rounded-lg border border-accent-500/30 bg-accent-500/5 p-5">
      <p class="font-mono text-xs text-accent-400">CONSEIL #2 — DIPLÔME ≠ COMPÉTENCE</p>
      <p class="mt-2 text-sm text-ink-200">
        Le diplôme ouvre la porte du premier entretien. Le portfolio (projets persos, GitHub, écrits) la franchit.
        Commence à construire <em>quelque chose</em> dès maintenant, peu importe la voie choisie.
      </p>
    </div>
  </div>
</Layout>
