---
import Layout from "../layouts/Layout.astro";
---

<Layout title="🥷">
  <div class="py-16 text-center space-y-6">
    <p class="text-7xl">🥷</p>
    <h1 class="font-display text-3xl font-bold">Tu as trouvé.</h1>
    <p class="text-ink-400 max-w-md mx-auto">
      Ce n'est ni dans la nav, ni dans le sitemap, ni dans le footer. Tu es arrivé·e ici par curiosité,
      par hasard, ou en sniffant le réseau. Bravo dans tous les cas.
    </p>
    <p id="status" class="font-mono text-sm text-terminal-amber">$ unlocking ninja badge…</p>
    <a href="/" class="inline-block rounded border border-ink-700 px-5 py-2 text-sm hover:border-accent-500">
      ← Retour au site
    </a>
  </div>

  <script>
    fetch('/api/easter-egg/secret-page', { method: 'POST', credentials: 'include' })
      .then((r) => r.json())
      .then((d) => {
        const el = document.getElementById('status');
        if (!el) return;
        if (d.badges_granted?.length) {
          el.textContent = '✓ Badge 🥷 Ninja débloqué — va voir sur /profil';
          el.className = 'font-mono text-sm text-terminal-green';
        } else {
          el.textContent = '✓ Badge déjà débloqué.';
          el.className = 'font-mono text-sm text-ink-500';
        }
      })
      .catch(() => {
        const el = document.getElementById('status');
        if (el) {
          el.textContent = '(connecte-toi d\'abord pour débloquer le badge)';
          el.className = 'font-mono text-sm text-ink-500';
        }
      });
  </script>
</Layout>
