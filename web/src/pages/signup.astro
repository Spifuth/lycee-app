---
import Layout from "../layouts/Layout.astro";
import AuthModal from "../components/AuthModal";
---

<Layout title="Inscription">
  <div class="mx-auto max-w-md py-8">
    <h1 class="mb-2 font-display text-3xl font-bold">Crée ton compte</h1>
    <p class="mb-6 text-ink-400">Choisis un pseudo. On te donne une passphrase à garder.</p>
    <AuthModal client:load initialMode="signup" forcedOpen />
  </div>
</Layout>
